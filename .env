# NEVER share this file or commit it to GitHub.
 
# ── MongoDB Connection ────────────────────────────────────────────────────────
# Option A: MongoDB Atlas (cloud, free tier available at https://cloud.mongodb.com)
# Replace <username>, <password>, and <cluster> with your actual Atlas credentials:
# MONGO_URI=mongodb://localhost:27017/newsbie
MONGO_URI=mongodb://mongo:sldQAqYCVfpJmSaMjOnzBeuyGYuMnZDj@crossover.proxy.rlwy.net:35976/newsbie
# Option B: Local MongoDB (if MongoDB is installed on your computer)
# MONGO_URI=mongodb://localhost:27017/newsbie

# On Railway, PORT is injected automatically — do NOT hardcode it here.
# This value is only used for local development.
PORT=8080

# ── JWT Secret ───────────────────────────────────────────────────────────────
# This is used to sign login tokens. Use a long random string in production.
JWT_SECRET=my_super_secret_newsbie_key_change_this_in_production
